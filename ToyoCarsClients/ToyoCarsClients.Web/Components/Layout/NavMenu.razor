@rendermode InteractiveServer

@* <Authorized> *@
@if (username is not null)
{
    <MudNavMenu>
        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
            <MudText Style="color: #333;">Inicio</MudText>
        </MudNavLink>
        <MudNavLink Href="/spaces" Icon="@Icons.Material.Filled.GridView">
            <MudText Style="color: #333;">Espacios</MudText>
        </MudNavLink>
        <MudNavLink Href="/reservas" Icon="@Icons.Material.Filled.BookOnline">
            <MudText Style="color: #333;">Mis Reservas</MudText>
        </MudNavLink>
           
        <MudNavLink Href="/perfil" Icon="@Icons.Material.Filled.Person">
            <MudText Style="color: #333;">Perfil</MudText>
        </MudNavLink>            
    </MudNavMenu>
}
@* </Authorized> *@

@code {
    [Parameter]
    public string username { get; set; }

}